POSTGRES_DB=tiktok_redirect
POSTGRES_USER=tiktok_redirect
POSTGRES_PASSWORD=tiktok_redirect_password
POSTGRES_PORT=5432

DATABASE_URL=postgres://tiktok_redirect:tiktok_redirect_password@localhost:5432/tiktok_redirect
PGSSLMODE=disable

# Production providers such as Neon can use DB_* instead of DATABASE_URL.
# DB_HOST=
# DB_PORT=5432
# DB_NAME=
# DB_USERNAME=
# DB_PASSWORD=
# DB_SSL=true

PG_POOL_MAX=5
